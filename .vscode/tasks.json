{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "monkeyc-build",
            "type": "shell",
            "command": "${env:CONNECTIQ_SDK}/bin/monkeyc -f manifest.xml -o ${workspaceFolder}/bin/FirstApp.iq -y",
            "presentation": { "reveal": "always" },
            "problemMatcher": []
        },
        {
            "label": "simulator-run",
            "type": "shell",
            "command": "${env:CONNECTIQ_SDK}/bin/simulator -f ${workspaceFolder}/bin/FirstApp.iq -d venu3",
            "presentation": { "reveal": "always" },
            "problemMatcher": []
        },
        {
            "label": "Build & Run Simulator",
            "dependsOn": [ "monkeyc-build", "simulator-run" ],
            "dependsOrder": "sequence",
            "presentation": { "reveal": "always" }
        }
    ]
}
